{
  // ─────────────────────────────────────────────────────────────
  //  BASE — heredado por TODOS los tsconfigs del monorepo.
  //
  //  Regla: solo va acá lo que es IDÉNTICO en backend, frontend
  //  y packages. Cualquier cosa que varía por ambiente
  //  (lib, types, jsx, include, paths) va en el tsconfig hijo.
  //
  //  Los hijos FUSIONAN, no reemplazan compilerOptions.
  //  Un hijo puede sobrescribir cualquier campo simplemente
  //  redeclarándolo — el hijo siempre gana.
  //
  //  include/exclude/files SÍ reemplazan completamente
  //  (no se fusionan), por eso no los ponemos acá.
  // ─────────────────────────────────────────────────────────────
  "compilerOptions": {
    // ── Módulos ─────────────────────────────────────────────────
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,

    // ── Interop ─────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    // ── Performance ─────────────────────────────────────────────
    "skipLibCheck": true,

    // ── Strictness base ─────────────────────────────────────────
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  }
}
