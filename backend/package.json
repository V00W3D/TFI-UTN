{
  "name": "backend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -b --noEmit && bun build src/index.ts --outdir dist --target bun",
    "start": "node dist/index.js",
    "prisma:generate": "bunx prisma generate --schema=src/config/db/prisma/schema.prisma",
    "prisma:migrate": "bunx prisma migrate dev --schema=src/config/db/prisma/schema.prisma",
    "prisma:migrate:reset": "bunx prisma migrate reset --schema=src/config/db/prisma/schema.prisma",
    "prisma:studio": "bunx prisma studio --schema=src/config/db/prisma/schema.prisma",
    "postinstall": "bunx prisma generate --schema=src/config/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@trpc/server": "^11.12.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.19.0",
    "flags": "^4.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "prisma": "^7.4.2"
  }
}
