{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",

    "moduleResolution": "bundler",

    "lib": ["ESNext"],

    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "strict": true,

    "skipLibCheck": true,

    "verbatimModuleSyntax": true,

    "isolatedModules": true,

    "moduleDetection": "force",

    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@tools/*": ["../backend/src/tools/*"]
    }
  },

  "include": ["**/*.ts"],

  "exclude": ["node_modules", "dist"]
}
