VITE_MODE=dev
VITE_PUBLIC_APP_SCOPE=landing
VITE_HOSTING_PROFILE=standard

# Misma IP/puerto que el API, o solo Tailscale:
# VITE_HOSTING_PROFILE=local_tailscale
# VITE_TAILSCALE_DEVICE_IP=100.x.x.x
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=3000

# Opcional: forzar URL completa o cadena vacía para proxy same-origin
# VITE_BACKEND_URL=
# VITE_BACKEND_URL=https://api.example.com
