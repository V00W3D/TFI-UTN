{
  "name": "@apps/backend",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun run prisma:generate && bun run prisma:studio:bg & bun --watch index.ts",
    "build": "bun build index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "prisma:generate": "prisma generate --schema ../../libs/server/db/prisma/schema.prisma",
    "generate": "bun run prisma:generate",
    "generate:reset": "rm -rf ../../libs/server/db/prisma/generated && bun run prisma:generate",
    "migrate": "prisma migrate dev --schema ../../libs/server/db/prisma/schema.prisma",
    "studio": "prisma studio --schema ../../libs/server/db/prisma/schema.prisma",
    "prisma:studio:bg": "prisma studio --schema ../../libs/server/db/prisma/schema.prisma --browser none"
  }
}
