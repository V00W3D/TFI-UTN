generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════
// USUARIOS Y ACCESO
// ═══════════════════════════════════════════════════════════════

model User {
  id       String   @id @default(uuid())
  name     String   @db.VarChar(128)
  sname    String?  @db.VarChar(128)
  lname    String   @db.VarChar(128)
  sex      Sex      @default(OTHER)
  username String   @unique @db.VarChar(32)
  password String   @db.VarChar(128)
  email    String   @unique @db.VarChar(128)
  phone    String?  @unique @db.VarChar(15)
  role     UserRole @default(CUSTOMER)

  customer  CustomerProfile?
  staff     StaffProfile?
  authority AuthorityProfile?
  reviews   Review[]
  /** Ventas registradas desde el canal web (opcional). */
  customerSales Sale[] @relation("CustomerSale")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier   CustomerTier @default(REGULAR)
}

model StaffProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   StaffPost
}

model AuthorityProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rank   AuthorityRank
}

// ═══════════════════════════════════════════════════════════════
// CATÁLOGO GASTRONÓMICO
// ═══════════════════════════════════════════════════════════════

// Nutrición explícita y plana: evita composites ambiguos y permite describir
// mejor casos como palta, frutos secos o pescados grasos sin reducir todo a
// un "health score" simplista.
model Ingredient {
  id                     String             @id @default(uuid())
  name                   String             @unique @db.VarChar(64)
  description            String?            @db.VarChar(255)
  category               IngredientCategory
  subCategory            String?            @db.VarChar(64)
  primaryFlavor          FlavorProfile?
  nutritionBasisGrams    Float              @default(100)
  pricingBasisGrams      Float              @default(100)
  costPrice              Decimal            @default(0) @db.Decimal(10, 2)
  salePrice              Decimal            @default(0) @db.Decimal(10, 2)
  calories               Float              @default(0)
  proteins               Float              @default(0)
  carbs                  Float              @default(0)
  fats                   Float              @default(0)
  fiber                  Float              @default(0)
  sugars                 Float              @default(0)
  sodium                 Float              @default(0)
  saturatedFat           Float              @default(0)
  transFat               Float              @default(0)
  monounsaturatedFat     Float              @default(0)
  polyunsaturatedFat     Float              @default(0)
  allergens              Allergen[]
  dietaryTags            DietaryTag[]
  nutritionTags          NutritionTag[]
  notes                  String?            @db.VarChar(255)
  extraAttributes        Json?
  preferredSupplierId    String?
  preferredSupplier      Supplier?          @relation("PreferredIngredientSupplier", fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  defaultStorageType     StorageType        @default(AMBIENT)
  maxStockGrams          Float              @default(0)
  reorderPointGrams      Float              @default(0)
  variants               IngredientVariant[]
  inventoryLevels        InventoryLevel[]
  supplierSources        SupplierIngredient[]
  purchaseItems          PurchaseItem[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([preferredSupplierId])
}

model IngredientVariant {
  id                           String            @id @default(uuid())
  ingredientId                 String
  ingredient                   Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  name                         String            @db.VarChar(64)
  description                  String?           @db.VarChar(255)
  preparationMethod            PreparationMethod @default(RAW)
  preparationNotes             String?           @db.VarChar(255)
  portionGrams                 Float             @default(100)
  yieldFactor                  Float             @default(1)
  overrideCalories             Float?
  overrideProteins             Float?
  overrideCarbs                Float?
  overrideFats                 Float?
  overrideFiber                Float?
  overrideSugars               Float?
  overrideSodium               Float?
  overrideSaturatedFat         Float?
  overrideTransFat             Float?
  overrideMonounsaturatedFat   Float?
  overridePolyunsaturatedFat   Float?
  isDefault                    Boolean           @default(false)
  recipeItems                  RecipeItem[]
  plateAdjustments             PlateAdjustment[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ingredientId, name])
  @@index([ingredientId, preparationMethod])
}

model Recipe {
  id              String         @id @default(uuid())
  name            String         @db.VarChar(128)
  description     String?        @db.Text
  type            PlateType
  flavor          FlavorProfile
  difficulty      Difficulty     @default(MEDIUM)
  prepTimeMinutes Int?
  cookTimeMinutes Int?
  yieldServings   Int            @default(1)
  assemblyNotes   String?        @db.Text
  allergens       Allergen[]
  dietaryTags     DietaryTag[]
  items           RecipeItem[]
  plates          Plate[]

  isPublic  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeItem {
  id              String            @id @default(uuid())
  recipeId        String
  recipe          Recipe            @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  variantId       String
  variant         IngredientVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantityGrams   Float
  prepNotes       String?           @db.VarChar(255)
  isOptional      Boolean           @default(false)
  isMainComponent Boolean           @default(false)
  sortOrder       Int               @default(0)
  plateAdjustments PlateAdjustment[]

  @@unique([recipeId, sortOrder])
  @@index([variantId])
}

model Plate {
  id                           String        @id @default(uuid())
  name                         String        @db.VarChar(128)
  description                  String?       @db.Text
  imageUrl                     String?       @db.VarChar(255)
  recipeId                     String
  recipe                       Recipe        @relation(fields: [recipeId], references: [id], onDelete: Restrict)
  size                         PlateSize     @default(REGULAR)
  servedWeightGrams            Float?
  netPrice                     Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount                    Decimal       @default(0) @db.Decimal(10, 2)
  profitAmount                 Decimal       @default(0) @db.Decimal(10, 2)
  profitMarginRate             Decimal       @default(0.3) @db.Decimal(5, 4)
  costPrice                    Decimal       @default(0) @db.Decimal(10, 2)
  menuPrice                    Decimal       @default(0) @db.Decimal(10, 2)
  avgRating                    Float         @default(0)
  ratingsCount                 Int           @default(0)
  likesCount                   Int           @default(0)
  dislikesCount                Int           @default(0)
  // Cache legacy del plato final ya resuelto.
  // El runtime customer debe calcular nutricion desde recipe.items + adjustments.
  // Pendiente de migracion futura: remover estos campos cuando el backfill deje de ser necesario.
  calculatedCalories           Float         @default(0)
  calculatedProteins           Float         @default(0)
  calculatedCarbs              Float         @default(0)
  calculatedFats               Float         @default(0)
  calculatedFiber              Float         @default(0)
  calculatedSugars             Float         @default(0)
  calculatedSodium             Float         @default(0)
  calculatedSaturatedFat       Float         @default(0)
  calculatedTransFat           Float         @default(0)
  calculatedMonounsaturatedFat Float         @default(0)
  calculatedPolyunsaturatedFat Float         @default(0)
  // Pueden diferir de la receta base si el plato aplica ajustes.
  allergens                    Allergen[]
  dietaryTags                  DietaryTag[]
  nutritionTags                NutritionTag[]
  nutritionNotes               String?       @db.VarChar(255)
  adjustments                  PlateAdjustment[]
  reviews                      Review[]
  tags                         PlateTag[]
  saleItems                    SaleItem[]

  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([recipeId])
  @@index([isAvailable, menuPrice])
}

// Ajustes a nivel plato: permiten describir un SKU/menu-item derivado de una
// receta base sin duplicar todos los componentes.
model PlateAdjustment {
  id             String             @id @default(uuid())
  plateId         String
  plate           Plate              @relation(fields: [plateId], references: [id], onDelete: Cascade)
  // REMOVAL: recipeItemId
  // ADDITION: variantId
  // SUBSTITUTION: recipeItemId + variantId
  recipeItemId    String?
  recipeItem      RecipeItem?        @relation(fields: [recipeItemId], references: [id], onDelete: SetNull)
  variantId       String?
  variant         IngredientVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  adjustmentType  AdjustmentType
  // Null = usar la cantidad original del recipe item cuando aplique.
  quantityGrams   Float?
  notes           String?            @db.VarChar(255)
  sortOrder       Int                @default(0)

  @@index([plateId, sortOrder])
  @@index([plateId, adjustmentType])
  @@index([recipeItemId])
  @@index([variantId])
}

// ═══════════════════════════════════════════════════════════════
// OPERACIONES, COSTOS Y PRECIOS
// ═══════════════════════════════════════════════════════════════

model Supplier {
  id                  String               @id @default(uuid())
  name                String               @unique @db.VarChar(96)
  description         String?              @db.VarChar(255)
  contactName         String?              @db.VarChar(96)
  email               String?              @db.VarChar(128)
  phone               String?              @db.VarChar(32)
  leadTimeDays        Int?
  notes               String?              @db.VarChar(255)
  preferredIngredients Ingredient[]        @relation("PreferredIngredientSupplier")
  suppliedIngredients SupplierIngredient[]
  purchases           Purchase[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupplierIngredient {
  id                String     @id @default(uuid())
  supplierId        String
  supplier          Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  ingredientId      String
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplierSku       String?    @db.VarChar(64)
  purchaseUnitLabel String?    @db.VarChar(32)
  pricingBasisGrams Float      @default(100)
  unitCostNet       Decimal    @default(0) @db.Decimal(10, 2)
  minimumOrderGrams Float?
  leadTimeDays      Int?
  isPreferred       Boolean    @default(false)
  lastQuotedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, ingredientId])
  @@index([ingredientId])
}

model StorageLocation {
  id            String           @id @default(uuid())
  name          String           @unique @db.VarChar(64)
  description   String?          @db.VarChar(255)
  storageType   StorageType
  capacityGrams Float            @default(0)
  notes         String?          @db.VarChar(255)
  inventoryLevels InventoryLevel[]
  purchaseItems PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryLevel {
  id                  String          @id @default(uuid())
  ingredientId        String
  ingredient          Ingredient      @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  storageLocationId   String
  storageLocation     StorageLocation @relation(fields: [storageLocationId], references: [id], onDelete: Cascade)
  currentQuantityGrams Float          @default(0)
  reservedQuantityGrams Float         @default(0)
  maxQuantityGrams    Float           @default(0)
  reorderPointGrams   Float           @default(0)
  averageUnitCost     Decimal         @default(0) @db.Decimal(10, 2)
  lastPurchaseUnitCost Decimal        @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ingredientId, storageLocationId])
  @@index([storageLocationId])
}

model TaxRule {
  id                  String   @id @default(uuid())
  key                 String   @unique @db.VarChar(48)
  name                String   @db.VarChar(64)
  description         String?  @db.VarChar(255)
  rate                Decimal  @default(0) @db.Decimal(8, 4)
  includedInMenuPrice Boolean  @default(true)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  sourceLabel         String?  @db.VarChar(96)
  note                String?  @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id            String         @id @default(uuid())
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  documentNumber String?       @db.VarChar(64)
  purchasedAt   DateTime       @default(now())
  receivedAt    DateTime?
  status        PurchaseStatus @default(RECEIVED)
  currencyCode  String         @default("ARS") @db.VarChar(3)
  subtotalNet   Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal        @default(0) @db.Decimal(12, 2)
  notes         String?        @db.VarChar(255)
  items         PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId, purchasedAt])
}

model PurchaseItem {
  id                String           @id @default(uuid())
  purchaseId        String
  purchase          Purchase         @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ingredientId      String
  ingredient        Ingredient       @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  quantityGrams     Float
  pricingBasisGrams Float            @default(100)
  unitCostNet       Decimal          @default(0) @db.Decimal(10, 2)
  taxRate           Decimal          @default(0) @db.Decimal(8, 4)
  lineNetAmount     Decimal          @default(0) @db.Decimal(12, 2)
  lineTaxAmount     Decimal          @default(0) @db.Decimal(12, 2)
  lineTotalAmount   Decimal          @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([purchaseId])
  @@index([ingredientId])
  @@index([storageLocationId])
}

model Sale {
  id           String      @id @default(uuid())
  soldAt       DateTime    @default(now())
  status       SaleStatus  @default(CONFIRMED)
  channel      SaleChannel @default(COUNTER)
  currencyCode String      @default("ARS") @db.VarChar(3)
  subtotalNet  Decimal     @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal     @default(0) @db.Decimal(12, 2)
  notes        String?     @db.VarChar(255)
  /** Cliente logueado al momento del pedido (web); invitados en null. */
  customerUserId String?
  customerUser   User?     @relation("CustomerSale", fields: [customerUserId], references: [id], onDelete: SetNull)
  items        SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([soldAt, status])
  @@index([customerUserId])
}

model SaleItem {
  id             String   @id @default(uuid())
  saleId         String
  sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  plateId        String
  plate          Plate    @relation(fields: [plateId], references: [id], onDelete: Restrict)
  quantity       Int      @default(1)
  unitCostAmount Decimal  @default(0) @db.Decimal(10, 2)
  unitNetAmount  Decimal  @default(0) @db.Decimal(10, 2)
  unitTaxAmount  Decimal  @default(0) @db.Decimal(10, 2)
  unitTotalAmount Decimal @default(0) @db.Decimal(10, 2)
  lineCostAmount Decimal  @default(0) @db.Decimal(12, 2)
  lineNetAmount  Decimal  @default(0) @db.Decimal(12, 2)
  lineTaxAmount  Decimal  @default(0) @db.Decimal(12, 2)
  lineTotalAmount Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([plateId])
}

// ═══════════════════════════════════════════════════════════════
// FEEDBACK Y ETIQUETADO
// ═══════════════════════════════════════════════════════════════

model Review {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plateId    String
  plate      Plate    @relation(fields: [plateId], references: [id], onDelete: Cascade)
  rating     Float
  comment    String?  @db.VarChar(500)
  recommends Boolean?
  createdAt  DateTime @default(now())

  @@unique([userId, plateId])
  @@index([plateId, rating])
}

model Tag {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(32)
  description String?  @db.VarChar(128)
  isActive    Boolean  @default(true)
  plates      PlateTag[]
  createdAt   DateTime @default(now())
}

model PlateTag {
  plateId String
  tagId   String

  plate Plate @relation(fields: [plateId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([plateId, tagId])
  @@index([tagId])
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  CUSTOMER
  STAFF
  AUTHORITY
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum CustomerTier {
  REGULAR
  VIP
  PREMIUM
}

enum StaffPost {
  COOK
  CASHIER
  WAITER
  BARISTA
  CLEANER
  DELIVERY
}

enum AuthorityRank {
  SUPERVISOR
  MANAGER
  DIRECTOR
  OWNER
}

enum IngredientCategory {
  PROTEIN_ANIMAL
  PROTEIN_PLANT
  VEGETABLE
  FRUIT
  LEGUME
  GRAIN
  BREAD
  DAIRY
  FAT
  SAUCE
  CONDIMENT
  SWEETENER
  BEVERAGE
  OTHER
}

enum PreparationMethod {
  RAW
  GRILLED
  FRIED
  BAKED
  ROASTED
  SAUTEED
  BOILED
  STEAMED
  SMOKED
  PICKLED
  FERMENTED
}

enum PlateType {
  STARTER
  MAIN
  DESSERT
  SIDE
  SNACK
  DRINK
}

enum FlavorProfile {
  SWEET
  SALTY
  ACID
  BITTERSWEET
  UMAMI
  SPICY
  UNKNOWN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  CHEF
}

enum PlateSize {
  SMALL
  REGULAR
  LARGE
  XL
}

enum StorageType {
  AMBIENT
  COLD
  FREEZER
  PRODUCE
}

enum AdjustmentType {
  ADDITION
  REMOVAL
  SUBSTITUTION
}

enum PurchaseStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

enum SaleStatus {
  OPEN
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum SaleChannel {
  COUNTER
  TAKEAWAY
  DELIVERY
  ONLINE
}

enum Allergen {
  GLUTEN
  MILK
  EGG
  PEANUT
  TREE_NUT
  SOY
  SESAME
  FISH
  SHELLFISH
  MUSTARD
  CELERY
  SULFITES
}

enum DietaryTag {
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  DAIRY_FREE
  NUT_FREE
  LOW_CARB
  KETO_COMPATIBLE
  PALEO_COMPATIBLE
  PESCATARIAN
}

enum NutritionTag {
  HIGH_PROTEIN
  HIGH_FIBER
  HIGH_HEALTHY_FATS
  LOW_SUGAR
  LOW_SODIUM
  WHOLE_FOOD
  MINIMALLY_PROCESSED
  ENERGY_DENSE
  SATIATING
}
