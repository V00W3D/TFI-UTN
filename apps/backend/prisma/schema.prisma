generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id String @id @default(uuid())

  name  String  @db.VarChar(128)
  sname String? @db.VarChar(128)
  lname String  @db.VarChar(128)
  sex   Sex     @default(OTHER)

  username String @unique @db.VarChar(32)
  password String @db.VarChar(128)

  email String  @unique @db.VarChar(128)
  phone String? @unique @db.VarChar(15)

  role UserRole @default(CUSTOMER)

  customer  CustomerProfile?
  staff     StaffProfile?
  authority AuthorityProfile?

  plates   Plate[]
  reviews  Review[]
  stats    CreatorStats?

  // 🔥 RELACIÓN INVERSA PARA TAGS
  createdTags Tag[]

  createdat DateTime @default(now())
  updatedat DateTime @updatedAt
}

// ─────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────

model CustomerProfile {
  userId String      @id
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier   CustomerTier @default(REGULAR)
}

enum CustomerTier {
  REGULAR
  VIP
  PREMIUM
}

// ─────────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────────

model StaffProfile {
  userId String    @id
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   StaffPost
}

enum StaffPost {
  COOK
  CASHIER
  WAITER
  BARISTA
  CLEANER
  DELIVERY
}

// ─────────────────────────────────────────────
// AUTHORITY
// ─────────────────────────────────────────────

model AuthorityProfile {
  userId String        @id
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rank   AuthorityRank
}

enum AuthorityRank {
  SUPERVISOR
  MANAGER
  DIRECTOR
  OWNER
}

// ─────────────────────────────────────────────
// PLATE
// ─────────────────────────────────────────────

model Plate {
  id String @id @default(uuid())

  name        String  @db.VarChar(128)
  description String?

  source PlateSource
  type   PlateType
  flavor FlavorProfile

  creatorId String?
  creator   User? @relation(fields: [creatorId], references: [id])

  avgRating    Float @default(0)
  ratingsCount Int   @default(0)

  isAvailable Boolean @default(true)

  ingredients PlateIngredient[]
  reviews     Review[]

  // 🔥 RELACIÓN INVERSA PARA TAGS
  tags PlateTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// INGREDIENT
// ─────────────────────────────────────────────

model Ingredient {
  id String @id @default(uuid())

  name String @unique @db.VarChar(64)

  flavor FlavorProfile

  isActive Boolean @default(true)

  plates PlateIngredient[]
}

// ─────────────────────────────────────────────
// PLATE - INGREDIENT
// ─────────────────────────────────────────────

model PlateIngredient {
  plateId      String
  ingredientId String

  plate      Plate      @relation(fields: [plateId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([plateId, ingredientId])
}

// ─────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────

model Review {
  id String @id @default(uuid())

  userId  String
  plateId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plate Plate @relation(fields: [plateId], references: [id], onDelete: Cascade)

  rating Float
  comment String? @db.VarChar(500)

  createdAt DateTime @default(now())

  @@unique([userId, plateId])
}

// ─────────────────────────────────────────────
// CREATOR STATS
// ─────────────────────────────────────────────

model CreatorStats {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalPlates     Int   @default(0)
  totalOrders     Int   @default(0)
  avgRating       Float @default(0)
  reputationScore Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// TAG
// ─────────────────────────────────────────────

model Tag {
  id String @id @default(uuid())

  name String @unique @db.VarChar(32)

  isApproved Boolean @default(false)
  isActive   Boolean @default(true)

  // 🔥 NUEVO
  usageCount Int @default(0)

  createdById String?
  createdBy   User? @relation(fields: [createdById], references: [id])

  plates PlateTag[]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// PLATE - TAG
// ─────────────────────────────────────────────

model PlateTag {
  plateId String
  tagId   String

  plate Plate @relation(fields: [plateId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([plateId, tagId])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum PlateSource {
  Q
  C
}

enum PlateType {
  STARTER
  MAIN
  DESSERT
  SIDE
  SNACK
  DRINK
}

enum FlavorProfile {
  SWEET
  SALTY
  ACID
  BITTERSWEET
  UMAMI
  UNKNOWN
}

enum UserRole {
  CUSTOMER
  STAFF
  AUTHORITY
}

enum Sex {
  MALE
  FEMALE
  OTHER
}
