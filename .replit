modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BUN_MODE = "dev"
BACKEND_PORT = "3000"
BACKEND_HOST = "localhost"
FRONTEND_PORT = "5000"
FRONTEND_HOST = "0.0.0.0"
VITE_MODE = "dev"
VITE_BACKEND_HOST = "localhost"
VITE_BACKEND_PORT = "3000"
