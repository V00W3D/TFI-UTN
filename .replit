modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BUN_MODE = "dev"
BACKEND_PORT = "3000"
BACKEND_HOST = "0.0.0.0"
FRONTEND_PORT = "5000"
FRONTEND_HOST = "0.0.0.0"
VITE_MODE = "dev"
VITE_BACKEND_HOST = "localhost"
VITE_BACKEND_PORT = "3000"
REFRESH_SECRET = "SOyYzFxJdnQu9hSJ25qI0GMxHYb4RciDEhqrlBB91tSWnBBodKR+xuxo7mfW+5+WkeNj1rAruUzmGKUAZWz3mg=="
VITE_BACKEND_URL = ""

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/backend && bun install && bun dev"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/frontend && bun install && bun dev"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "bun --cwd apps/backend start & bun --cwd apps/frontend preview --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "bun install && bun --cwd apps/backend run build && bun --cwd apps/frontend run build"]
